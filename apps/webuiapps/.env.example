# CDN prefix for static assets (optional, leave empty for local assets)
CDN_PREFIX=

# TTS lab / in-app voice playback (optional, needed for Aoi voice playback)
GEMINI_API_KEY=
ELEVENLABS_API_KEY=

# RUM monitoring (optional)
VITE_RUM_SITE=
VITE_RUM_CLIENT_TOKEN=

# Sentry error tracking (optional, plugin only loads when SENTRY_AUTH_TOKEN is set)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
